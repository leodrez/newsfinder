# Anthropic (required for LLM scoring)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase (required for storage, dedup, and Realtime)
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # secret — server only, never expose to browser

# Upstash QStash (required for signature verification in production)
# Get from: https://console.upstash.com/qstash
QSTASH_CURRENT_SIGNING_KEY=sig_your-current-key
QSTASH_NEXT_SIGNING_KEY=sig_your-next-key

# ── Frontend env vars (prefix with VITE_ so Vite bundles them) ───────────────
# These are safe to expose in the browser — RLS restricts the anon key to read-only.
VITE_SUPABASE_URL=https://your-project.supabase.co   # same value as SUPABASE_URL
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # public anon key

# Optional: override the LLM model
# LLM_MODEL=claude-haiku-4-5-20251001
